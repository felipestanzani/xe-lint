{
  "name": "xe-lint",
  "version": "1.0.0",
  "description": "ESLint config that implements our style guide and helps to catch errors. This is a fork of https://github.com/molindo/eslint-config-molindo",
  "repository": "https://github.com/felipestanzani/xe-lint",
  "author": "Felipe Stanzani <stanzani@gmail.com>",
  "type": "module",
  "license": "MIT",
  "main": "src/index.js",
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "scripts": {
    "lint": "eslint src && prettier src --check",
    "prepublish": "npm run lint"
  },
  "files": [
    "src",
    ".prettierrc.json",
    "tsconfig.json"
  ],
  "devDependencies": {
    "@types/confusing-browser-globals": "^1.0.3",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@eslint/js": "^9.11.1",
    "@typescript-eslint/utils": "^8.0.0",
    "@vitest/eslint-plugin": "^1.1.7",
    "confusing-browser-globals": "^1.0.11",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-css-modules": "^2.11.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.2.3",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "eslint-plugin-tailwindcss": "^3.13.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "typescript-eslint": "^8.8.0"
  }
