{
  "name": "xe-lint",
  "version": "1.0.0",
  "description": "ESLint config that implements our style guide and helps to catch errors. This is a fork of https://github.com/molindo/eslint-config-molindo",
  "repository": "https://github.com/felipestanzani/xe-lint",
  "author": "Felipe Stanzani <stanzani@gmail.com>",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "scripts": {
    "type-check": "tsc",
    "lint": "eslint --config eslint.config.dev.js src && prettier src --check",
    "prepublish": "npm run lint && npm run type-check"
  },
  "files": [
    "dist",
    "src",
    ".prettierrc.json",
    "tsconfig.json"
  ],
  "devDependencies": {
    "@types/confusing-browser-globals": "^1.0.3",
    "@types/eslint-plugin-jsx-a11y": "^6.10.0",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@eslint/js": "^9.36.0",
    "@typescript-eslint/utils": "^8.45.0",
    "@vitest/eslint-plugin": "^1.3.13",
    "confusing-browser-globals": "^1.0.11",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unicorn": "^61.0.2",
    "eslint-plugin-unused-imports": "^4.2.0",
    "typescript-eslint": "^8.45.0"
  }
}